# RustPulse production environment variables
APP_ENV=prod
HOST=0.0.0.0
PORT=8080

RUSTPULSE_STORAGE=postgres
DATABASE_URL=postgres://rustpulse:change-me@postgres:5432/rustpulse

# Required in prod
JWT_SECRET=change-me-to-32-chars-minimum

# Postgres container settings (used by Docker Compose)
POSTGRES_DB=rustpulse
POSTGRES_USER=rustpulse
POSTGRES_PASSWORD=change-me

# Optional
LOG_JSON=1
RUST_LOG=info
